#!/usr/bin/env bash
set -euo pipefail

# Deploy the integration to a Home Assistant instance via SMB.
#
# Configure via environment variables:
#   HA_HOST       — hostname of your HA instance (default: homeassistant.local)
#   HA_MOUNT_PATH — local mount point for the config share (default: /Volumes/config)

cd "$(dirname "$0")/.."

HA_HOST="${HA_HOST:-homeassistant.local}"
HA_MOUNT_PATH="${HA_MOUNT_PATH:-/Volumes/config}"

if ! mount | grep -qF " on ${HA_MOUNT_PATH} "; then
    echo "Mounting config share..."
    open "smb://${HA_HOST}/config"
    for i in $(seq 1 30); do
        [ -d "${HA_MOUNT_PATH}" ] && mount | grep -qF " on ${HA_MOUNT_PATH} " && break
        sleep 1
        printf "."
    done
    echo ""
    if ! mount | grep -qF " on ${HA_MOUNT_PATH} "; then
        echo "Timeout mounting config share"
        exit 1
    fi
    echo "Mounted smb://${HA_HOST}/config to ${HA_MOUNT_PATH}"
else
    echo "Already mounted at ${HA_MOUNT_PATH}"
fi

target="${HA_MOUNT_PATH}/custom_components/cloudflare_ai_gateway"
mkdir -p "$target" "$target/translations"
cp custom_components/cloudflare_ai_gateway/*.py "$target/"
cp custom_components/cloudflare_ai_gateway/*.json "$target/"
cp custom_components/cloudflare_ai_gateway/translations/*.json "$target/translations/"

echo "Deployed. Restart Home Assistant to load changes."
